# PostgreSQL connection string (required)
# For Vercel Postgres / Neon / Supabase / Railway etc.
DATABASE_URL=postgresql://user:password@host:5432/database

# Used to encrypt JWT tokens (required) — use a long random string
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Your production URL — no trailing slash (required)
# Example: https://your-site.vercel.app
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Secret used to authenticate cron jobs (optional)
CRON_SECRET=YOUR_CRON_SECRET_HERE

# Used to validate preview requests (optional)
PREVIEW_SECRET=YOUR_SECRET_HERE
